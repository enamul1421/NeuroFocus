{
  "expo": {
    "name": "NeuroFocus",
    "slug": "neurofocus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B5EA6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.westview.neurofocus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B5EA6"
      },
      "package": "com.westview.neurofocus"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5B5EA6"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
